{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digitalpals.dev/portal-hub/contracts/v2/vault-enrollment-create-request.schema.json",
  "title": "Portal Hub API v2 vault enrollment create request",
  "type": "object",
  "required": ["device_name", "public_key_algorithm", "public_key_der_base64"],
  "properties": {
    "device_name": { "type": "string", "minLength": 1 },
    "public_key_algorithm": { "const": "RSA-OAEP-SHA256" },
    "public_key_der_base64": { "type": "string", "minLength": 1 },
    "pairing_id": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": false
}
